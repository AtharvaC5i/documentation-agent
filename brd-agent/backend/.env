# ─── Databricks Configuration ─────────────────────────────────────────────────
# Your Databricks workspace URL (no trailing slash)
# Example: https://adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HOST=https://adb-1860168467798787.7.azuredatabricks.net

# Personal Access Token from Databricks → User Settings → Access Tokens
DATABRICKS_TOKEN=dapi130bfc09ff99fbe4ad6bf008456d50a1-3

# The serving endpoint name you configured in Databricks Model Serving
# Default uses Meta Llama 3.3 70B — change to your endpoint name
DATABRICKS_MODEL_ENDPOINT=databricks-claude-sonnet-4-6

# ─── App Configuration ────────────────────────────────────────────────────────
# Port the FastAPI backend runs on
APP_PORT=8000

# Set to "production" in prod, "development" locally
APP_ENV=development
